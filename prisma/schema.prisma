// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id              Int              @id @default(autoincrement())
  fullName        String           @db.VarChar(100)
  email           String           @unique @db.VarChar(100)
  password        String           @db.VarChar(255)
  role            Role             @default(USER)
  createdAt       DateTime         @default(now())
  bookings        Booking[]
  businessProfile BusinessProfile?
  userProfile     UserProfile?
  savedPackages   SavedPackage[]
  favorites       Favorite[]

  @@map("users")
}

model UserProfile {
  id               Int     @id @default(autoincrement())
  userId           Int     @unique
  phoneNumber      String? @db.VarChar(20)
  address          String? @db.Text
  identityNumber   String? @db.VarChar(50) // KTP/Passport
  emergencyContact String? @db.VarChar(100)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model SavedPackage {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String   @db.VarChar(100)
  packageData Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_packages")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  locationId Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("favorites")
}

model BusinessProfile {
  id           Int            @id @default(autoincrement())
  userId       Int            @unique
  user         User           @relation(fields: [userId], references: [id])
  businessName String         @db.VarChar(150)
  status       ApprovalStatus @default(PENDING)
  locations    Location[]

  @@map("business_profiles")
}

model Location {
  id             Int             @id @default(autoincrement())
  businessId     Int
  business       BusinessProfile @relation(fields: [businessId], references: [id])
  isPublished    Boolean         @default(true)
  name           String          @db.VarChar(100)
  category       String          @db.VarChar(50) // Beach, Hill, Cafe, etc.
  address        String          @db.Text
  latitude       Decimal         @db.Decimal(10, 8)
  longitude      Decimal         @db.Decimal(11, 8)
  wifiSpeed      Int // Mbps
  hasPowerOutlet Boolean         @default(true)
  description    String          @db.Text
  img            String?         @db.VarChar(255)
  rating         Decimal         @default(0.0) @db.Decimal(3, 1)
  reviews        Int             @default(0)
  facilities     Json?
  suasana        Json?
  packages       Package[]
  favorites      Favorite[]

  @@map("locations")
}

model Package {
  id          Int       @id @default(autoincrement())
  locationId  Int?
  packageName String    @db.VarChar(100)
  pricePerDay Decimal   @db.Decimal(12, 2)
  customData  Json?
  location    Location? @relation(fields: [locationId], references: [id])
  bookings    Booking[]

  @@map("packages")
}

model Booking {
  id             Int             @id @default(autoincrement())
  userId         Int
  packageId      Int
  startDate      DateTime        @db.Date
  endDate        DateTime        @db.Date
  guestCount     Int             @default(1)
  totalPrice     Decimal         @db.Decimal(12, 2)
  status         BookingStatus   @default(PENDING)
  user           User            @relation(fields: [userId], references: [id])
  package        Package         @relation(fields: [packageId], references: [id])
  itineraries    Itinerary[]
  experienceLogs ExperienceLog[]
  review         Review?

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Itinerary {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  dayNumber      Int      @default(1)
  activityName   String   @db.VarChar(150)
  timeSlot       DateTime @db.Time
  isProductivity Boolean  @default(false)
  booking        Booking  @relation(fields: [bookingId], references: [id])

  @@map("itineraries")
}

model ExperienceLog {
  id        Int      @id @default(autoincrement())
  bookingId Int
  moodScore Int      @db.TinyInt
  note      String?  @db.Text
  loggedAt  DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@map("experience_logs")
}

model Review {
  id              Int      @id @default(autoincrement())
  bookingId       Int      @unique
  rating          Int      @db.TinyInt // Overall Rating
  wifiRating      Int      @db.TinyInt
  workspaceRating Int      @db.TinyInt
  ambienceRating  Int      @db.TinyInt
  comment         String?  @db.Text
  tags            Json?    
  photos          Json?    
  createdAt       DateTime @default(now())
  booking         Booking  @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}
