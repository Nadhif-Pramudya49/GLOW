// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String    @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255)
  role      String    @default("USER") // USER, ADMIN
  createdAt DateTime  @default(now())
  bookings  Booking[]

  @@map("users")
}

model Location {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)
  category        String    @db.VarChar(50) // Beach, Hill, Cafe, etc.
  address         String    @db.Text
  latitude        Decimal   @db.Decimal(10, 8)
  longitude       Decimal   @db.Decimal(11, 8)
  wifiSpeed       Int       // Mbps
  hasPowerOutlet  Boolean   @default(true)
  description     String    @db.Text
  img             String?   @db.VarChar(255)
  rating          Decimal   @default(0.0) @db.Decimal(3, 1)
  reviews         Int       @default(0)
  facilities      Json?
  suasana         Json?
  packages        Package[]

  @@map("locations")
}

model Package {
  id           Int       @id @default(autoincrement())
  locationId   Int
  packageName  String    @db.VarChar(100)
  pricePerDay  Decimal   @db.Decimal(12, 2)
  location     Location  @relation(fields: [locationId], references: [id])
  bookings     Booking[]

  @@map("packages")
}

model Booking {
  id             Int             @id @default(autoincrement())
  userId         Int
  packageId      Int
  startDate      DateTime        @db.Date
  endDate        DateTime        @db.Date
  guestCount     Int             @default(1)
  totalPrice     Decimal         @db.Decimal(12, 2)
  status         BookingStatus   @default(PENDING)
  user           User            @relation(fields: [userId], references: [id])
  package        Package         @relation(fields: [packageId], references: [id])
  itineraries    Itinerary[]
  experienceLogs ExperienceLog[]
  review         Review?

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Itinerary {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  dayNumber      Int      @default(1)
  activityName   String   @db.VarChar(150)
  timeSlot       DateTime @db.Time
  isProductivity Boolean  @default(false)
  booking        Booking  @relation(fields: [bookingId], references: [id])

  @@map("itineraries")
}

model ExperienceLog {
  id        Int      @id @default(autoincrement())
  bookingId Int
  moodScore Int      @db.TinyInt
  note      String?  @db.Text
  loggedAt  DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@map("experience_logs")
}

model Review {
  id               Int      @id @default(autoincrement())
  bookingId        Int      @unique
  rating           Int      @db.TinyInt // Overall Rating
  wifiRating       Int      @db.TinyInt
  workspaceRating  Int      @db.TinyInt
  ambienceRating   Int      @db.TinyInt
  comment          String?  @db.Text
  createdAt        DateTime @default(now())
  booking          Booking  @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}
